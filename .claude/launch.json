{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static HTML Server (npx serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-l", "3000", "."],
      "port": 3000
    },
    {
      "name": "Static HTML Server (Python)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8081"],
      "port": 8081
    }
  ]
}
